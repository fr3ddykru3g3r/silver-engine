{
  "name": "silver-engine",
  "version": "0.1.0",
  "description": "Local-only subscription tracker Electron app",
  "homepage": "https://github.com/your-org/silver-engine/releases",
  "main": "main/main.js",
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm:electron\"",
    "electron": "wait-on tcp:5173 && electron .",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.6",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.silverengine.app",
    "productName": "Silver Engine",
    "files": [
      "dist/renderer/**",
      "main/**",
      "storage/**",
      "core/**",
      "package.json"
    ],
    "directories": {
      "output": "dist/installers"
    },
    "publish": [
      "github"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
